# ฐานข้อมูล (ต้องมี)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Production: URL หลักของแอป (ลูกค้าสแกน QR จะเข้า URL นี้)
# ตัวอย่าง: https://pos.yourdomain.com หรือ https://yourdomain.com
NEXT_PUBLIC_APP_URL="pos.lamphucafe.com"
