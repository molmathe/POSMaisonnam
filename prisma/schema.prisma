generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== ระบบจัดการพนักงาน & เงินเดือน ==================
model Employee {
  id          Int          @id @default(autoincrement())
  name        String
  dailyWage   Float        // ค่าแรงรายวัน
  pinCode     String?      @unique // PIN สำหรับเจ้าของร้านใช้เช็คชื่อ (พนักงานทั่วไปจะไม่มี)
  role        Role         @default(STAFF)
  attendances Attendance[]
}

enum Role {
  OWNER
  STAFF
}

model Attendance {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  date        DateTime @default(now())
  extraPay    Float    @default(0) // เงินพิเศษ
  employee    Employee @relation(fields: [employeeId], references: [id])
}

// ================== ระบบร้าน & ลูกค้า ==================
model Table {
  id     Int     @id @default(autoincrement())
  name   String  @unique // เช่น โต๊ะ 1, โต๊ะ 2, VIP
  orders Order[]
}

model Customer {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  orders Order[]
}

// ================== ระบบเมนูอาหาร ==================
model Category {
  id    Int     @id @default(autoincrement())
  name  String  // จานหลัก, ทานเล่น, ของหวาน, น้ำ, น้ำอัดลม
  menus Menu[]
}

model Menu {
  id                  Int                  @id @default(autoincrement())
  categoryId          Int
  nameTh              String
  nameEn              String?
  imageUrl            String?
  price               Float
  cost                Float?               // เผื่ออนาคต: ต้นทุน
  deletedAt           DateTime?            // soft delete — ออเดอร์เก่ายังอ้างอิงได้
  category            Category             @relation(fields: [categoryId], references: [id])
  orderItems          OrderItem[]
  menuToppings        MenuTopping[]        // เมนูนี้เลือก topping อะไรได้บ้าง (ว่าง = ไม่แสดงบน POS)
  menuSpecialRequests MenuSpecialRequest[] // เมนูนี้เลือกคำขอพิเศษอะไรได้บ้าง (ว่าง = ไม่แสดงบน POS)
}

model MenuTopping {
  menuId    Int
  toppingId Int
  menu      Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  topping   Topping @relation(fields: [toppingId], references: [id], onDelete: Cascade)
  @@id([menuId, toppingId])
}

model Topping {
  id            Int           @id @default(autoincrement())
  name          String        // พิเศษ, ไข่ดาวสุก, เพิ่มหมู
  price         Float
  group         String?       // กลุ่มแสดงบน POS เช่น ไข่ดาว (ว่าง = แสดงแยก)
  menuToppings  MenuTopping[]
}

model SpecialRequest {
  id                  Int                  @id @default(autoincrement())
  name                String               // ไม่พริก, เผ็ดน้อย, ไม่ผัก
  menuSpecialRequests MenuSpecialRequest[]
}

model MenuSpecialRequest {
  menuId          Int
  specialRequestId Int
  menu            Menu           @relation(fields: [menuId], references: [id], onDelete: Cascade)
  specialRequest  SpecialRequest @relation(fields: [specialRequestId], references: [id], onDelete: Cascade)
  @@id([menuId, specialRequestId])
}

// ================== ระบบออเดอร์ ==================
model Order {
  id         Int         @id @default(autoincrement())
  tableId    Int?
  customerId Int?
  status     OrderStatus @default(PENDING) // รอชำระ, ชำระแล้ว, ยกเลิก
  totalPrice Float       @default(0)
  discount   Float       @default(0)        // ส่วนลดทั้งบิล (บาท)
  
  // สำหรับ QR Code ตรวจสอบรายการ 24 ชม.
  qrToken    String?     @unique
  qrExpires  DateTime?

  // ข้อมูลการชำระเงิน
  payMethod     PaymentMethod?
  paidAt        DateTime?
  cashReceived  Float?   // จำนวนเงินที่รับ (เมื่อชำระเงินสด)
  changeAmount  Float?   // เงินทอน

  // พนักงานที่รับออเดอร์
  servedBy   String?

  table      Table?      @relation(fields: [tableId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  QR
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  menuId       Int
  quantity     Int
  price        Float   // ราคา ณ วันที่สั่ง
  note         String? // Freetext สำหรับหมายเหตุเพิ่มเติม

  // เก็บข้อมูล Topping และ Request แบบ JSON เพื่อความยืดหยุ่น หรือจะแยก Table ก็ได้ (ในที่นี้ใช้ JSON Array ของ ID เพื่อง่ายต่อการดึงข้อมูล)
  toppings     Json?   // ex. [{ id: 1, name: "ไข่ดาว", price: 10 }]
  requests     Json?   // ex. ["ไม่พริก", "ไม่ผัก"]

  // ใช้สำหรับ track ว่ารายการนี้ส่งเข้าครัวแล้วหรือยัง
  sentToKitchen Boolean @default(false)
  // ครัวทำเสร็จแล้ว (กดจากจอคิว) — จำนวนจานที่ทำแล้ว (สำหรับ x2, x3 กดทีละจาน)
  kitchenPreparedCount Int       @default(0)
  kitchenPreparedAt    DateTime? // ตั้งเมื่อทำครบทุกจานแล้ว

  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu         Menu    @relation(fields: [menuId], references: [id])
}

// ================== ตั้งค่าระบบ (ใบเสร็จ, การแจ้งเตือน) ==================
model SystemSetting {
  id          Int     @id @default(autoincrement())
  key         String  @unique // เช่น RECEIPT_WIDTH, RECEIPT_HEADER, ENABLE_LINE_NOTI
  value       String
  description String?
}